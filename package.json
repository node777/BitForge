{
  "name": "bitforge-workshop-contracts",
  "version": "1.0.0",
  "description": "Smart contracts for BitForge Workshop - AI-powered trading tools and Virtuals Protocol integration",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deployment/deploy.js",
    "deploy:base": "hardhat run scripts/deployment/deploy.js --network base",
    "deploy:virtuals": "hardhat run scripts/deployment/deploy-virtuals.js --network base",
    "deploy:testnet": "hardhat run scripts/deployment/deploy.js --network baseGoerli",
    "verify": "hardhat verify --network base",
    "node": "hardhat node",
    "clean": "hardhat clean",
    "coverage": "hardhat coverage",
    "gas-report": "REPORT_GAS=true hardhat test",
    "slither": "slither .",
    "format": "prettier --write 'contracts/**/*.sol' 'scripts/**/*.js' 'test/**/*.js'",
    "lint": "solhint 'contracts/**/*.sol'",
    "size": "hardhat size-contracts",
    "docgen": "hardhat docgen",
    "prepare": "husky install"
  },
  "keywords": [
    "ethereum",
    "solidity",
    "smart-contracts",
    "defi",
    "trading",
    "ai",
    "virtuals-protocol",
    "base-network",
    "algorithmic-trading"
  ],
  "author": "BitForge Workshop Team",
  "license": "MIT",
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.3",
    "@openzeppelin/contracts-upgradeable": "^4.9.3",
    "dotenv": "^16.3.1",
    "ethers": "^5.7.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-network-helpers": "^1.0.9",
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-etherscan": "^3.1.7",
    "@typechain/ethers-v5": "^10.2.1",
    "@typechain/hardhat": "^6.1.6",
    "@types/chai": "^4.3.5",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.4.2",
    "chai": "^4.3.7",
    "hardhat": "^2.17.1",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-deploy": "^0.11.34",
    "hardhat-gas-reporter": "^1.0.9",
    "hardhat-storage-layout": "^0.1.7",
    "husky": "^8.0.3",
    "prettier": "^3.0.0",
    "prettier-plugin-solidity": "^1.1.3",
    "solhint": "^3.6.2",
    "solidity-coverage": "^0.8.4",
    "solidity-docgen": "^0.6.0-beta.36",
    "ts-node": "^10.9.1",
    "typechain": "^8.3.1",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/node777/BitForge-Workshop-Contracts.git"
  },
  "bugs": {
    "url": "https://github.com/node777/BitForge-Workshop-Contracts/issues"
  },
  "homepage": "https://github.com/node777/BitForge-Workshop-Contracts#readme",
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint && npm run format"
    }
  }
} 