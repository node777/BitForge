# BitForge Workshop Environment Configuration
# Copy this file to .env and fill in your actual values

# ================================
# DEPLOYMENT CONFIGURATION
# ================================

# Private key for deployment (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Network RPC URLs
BASE_RPC_URL=https://mainnet.base.org
BASE_GOERLI_RPC_URL=https://goerli.base.org
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR-PROJECT-ID
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR-PROJECT-ID

# ================================
# VERIFICATION CONFIGURATION
# ================================

# API Keys for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key
BASESCAN_API_KEY=your_basescan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# ================================
# VIRTUALS PROTOCOL CONFIGURATION
# ================================

# Virtuals Protocol contract addresses (Base network)
VIRTUALS_FACTORY_ADDRESS=0x8Bc7d8f3C9b8B9D8C8a6E5f4C3b2A1F0e9d8c7B6
VIRTUAL_TOKEN_ADDRESS=0x0b3e328455c4059eeb9e3f84b5543f74e24e7e1b

# Agent deployment configuration
TOTAL_VIRTUAL_BUDGET=5000
VIRTUAL_PER_AGENT=1000
GENESIS_LAUNCH=true

# ================================
# TRADING CONFIGURATION
# ================================

# DEX Router addresses
UNISWAP_V3_ROUTER=0x2626664c2603336E57B271c5C0b26F421741e481
UNISWAP_V3_FACTORY=0x33128a8fC17869897dcE68Ed026d694621f6FDfD

# Trading parameters
INITIAL_TRADING_CAPITAL=1.0
MAX_SLIPPAGE_PERCENT=5.0
STOP_LOSS_PERCENT=10.0
TAKE_PROFIT_PERCENT=20.0

# ================================
# FORGE TOKEN CONFIGURATION
# ================================

# Token economics
FORGE_INITIAL_SUPPLY=1000000000
FORGE_BURN_RATE=100
FORGE_TRANSFER_FEE=50
FORGE_MIN_STAKE=10000

# ================================
# GUILD CONFIGURATION
# ================================

# Risk management parameters
MAX_DRAWDOWN_PERCENT=20
MAX_POSITION_SIZE_PERCENT=10
MIN_SHARPE_RATIO=150

# Performance fees
PERFORMANCE_FEE_PERCENT=20
MANAGEMENT_FEE_PERCENT=2
PLATFORM_FEE_PERCENT=10

# ================================
# MONITORING & ANALYTICS
# ================================

# Gas reporting
REPORT_GAS=true
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# Monitoring services
DEFENDER_API_KEY=your_defender_api_key
DEFENDER_API_SECRET=your_defender_api_secret

# Debugging tools
TENDERLY_PROJECT=bitforge-workshop
TENDERLY_USERNAME=your_tenderly_username

# ================================
# REVENUE OPTIMIZATION
# ================================

# Revenue collection settings
REVENUE_COLLECTION_INTERVAL=3600
AUTO_COMPOUND_ENABLED=true
COMPOUND_THRESHOLD=0.1

# Cross-guild collaboration
CROSS_GUILD_ENABLED=true
GUILD_COLLABORATION_BONUS=150

# ================================
# SECURITY SETTINGS
# ================================

# Multi-sig configuration
MULTISIG_ENABLED=false
MULTISIG_THRESHOLD=2
MULTISIG_OWNERS=0x1234567890123456789012345678901234567890,0x2345678901234567890123456789012345678901

# Emergency settings
EMERGENCY_PAUSE_ENABLED=true
EMERGENCY_CONTACT=your_emergency_contact

# ================================
# TESTING CONFIGURATION
# ================================

# Test network settings
TEST_NETWORK_FORK=true
TEST_BLOCK_NUMBER=latest
TEST_ACCOUNT_FUNDING=100

# Test data
TEST_VIRTUAL_AMOUNT=1000
TEST_FORGE_AMOUNT=10000
TEST_TRADING_PAIRS=ETH/USDC,BTC/ETH

# ================================
# DEPLOYMENT PREFERENCES
# ================================

# Deployment strategy
DEPLOYMENT_STRATEGY=genesis
DEPLOYMENT_DELAY_HOURS=24
VERIFICATION_ENABLED=true

# Gas optimization
GAS_OPTIMIZATION_ENABLED=true
MAX_GAS_PRICE=50
GAS_LIMIT_MULTIPLIER=1.2

# ================================
# OPERATIONAL SETTINGS
# ================================

# Logging
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/bitforge.log

# Backup settings
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=30

# ================================
# INTEGRATION SETTINGS
# ================================

# External APIs
PRICE_FEED_API_KEY=your_price_feed_api_key
MARKET_DATA_API_KEY=your_market_data_api_key

# Social media integration
TWITTER_API_KEY=your_twitter_api_key
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# ================================
# ADVANCED CONFIGURATION
# ================================

# Custom contract addresses (leave empty for fresh deployment)
CUSTOM_FORGE_TOKEN_ADDRESS=
CUSTOM_WORKSHOP_ADDRESS=
CUSTOM_SCRIPT_ENGINE_ADDRESS=
CUSTOM_VIRTUALS_INTEGRATION_ADDRESS=

# Feature flags
ENABLE_ADVANCED_TRADING=true
ENABLE_CROSS_CHAIN=false
ENABLE_NFT_INTEGRATION=true
ENABLE_GOVERNANCE=true

# Performance tuning
BATCH_SIZE=10
PARALLEL_REQUESTS=5
CACHE_TTL=300

# ================================
# DEVELOPMENT SETTINGS
# ================================

# Development mode
DEV_MODE=false
SKIP_CONFIRMATIONS=false
FAST_DEPLOYMENT=false

# Testing overrides
OVERRIDE_SAFETY_CHECKS=false
SKIP_VERIFICATION=false
MOCK_VIRTUALS_PROTOCOL=false 